<UserControl x:Class="MEFExampleApp.Modules.Calculator.CalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20" MaxWidth="360" HorizontalAlignment="Left">

        <TextBlock Text="Calculator Module" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Text="This module was discovered by MEF at runtime from the Plugins folder."
                   TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,20"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding Left.Value, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Left.IsEnabled}"
                     Padding="6,4" FontSize="16" TextAlignment="Right"/>
            <TextBox Grid.Column="2" Text="{Binding Right.Value, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Right.IsEnabled}"
                     Padding="6,4" FontSize="16" TextAlignment="Right"/>
        </Grid>

        <UniformGrid Rows="1" Columns="4" Margin="0,10,0,0">
            <Button Content="+" Command="{Binding AddCommand}"      Margin="0,0,4,0" Padding="8,6" FontSize="16"/>
            <Button Content="-" Command="{Binding SubtractCommand}" Margin="4,0,4,0" Padding="8,6" FontSize="16"/>
            <Button Content="×" Command="{Binding MultiplyCommand}" Margin="4,0,4,0" Padding="8,6" FontSize="16"/>
            <Button Content="÷" Command="{Binding DivideCommand}"   Margin="4,0,0,0" Padding="8,6" FontSize="16"/>
        </UniformGrid>

        <Border Background="#F0F7FF" BorderBrush="#0078D4" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,16,0,0">
            <TextBlock Text="{Binding Result, FallbackValue='Choose an operation above'}"
                       FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>
    </StackPanel>
</UserControl>
