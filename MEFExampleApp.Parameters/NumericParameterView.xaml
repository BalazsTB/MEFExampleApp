<UserControl x:Class="MEFExampleApp.Parameters.NumericParameterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Reusable view for a numeric parameter.
        DataContext must be an INumericParameterViewModel (typically NumericParameterViewModel).
        Renders a prompt label followed by a right-aligned text box bound to Value.
        The text box border turns red when IsValid is false to signal invalid input.
    -->
    <StackPanel>
        <TextBlock Text="{Binding Prompt}" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsEnabled}"
                 TextAlignment="Right"
                 Padding="6,5" FontSize="14">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                            <Setter Property="BorderBrush" Value="#C42B1C"/>
                            <Setter Property="ToolTip" Value="Please enter a valid number"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
    </StackPanel>
</UserControl>
