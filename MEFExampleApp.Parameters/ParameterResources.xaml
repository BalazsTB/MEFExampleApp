<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MEFExampleApp.Parameters">

    <!--
        Implicit DataTemplates — no x:Key means WPF applies these automatically
        whenever it encounters a TextParameterViewModel or NumericParameterViewModel
        as content anywhere in the application.

        The shell merges this dictionary into Application.Current.Resources at startup,
        so modules can simply bind a parameter ViewModel to a ContentControl.Content
        and WPF will render the appropriate View with the correct DataContext.
    -->

    <DataTemplate DataType="{x:Type local:TextParameterViewModel}">
        <local:TextParameterView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NumericParameterViewModel}">
        <local:NumericParameterView/>
    </DataTemplate>

</ResourceDictionary>
