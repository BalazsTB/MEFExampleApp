<UserControl x:Class="MEFExampleApp.Modules.Greeting.GreetingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20" MaxWidth="400" HorizontalAlignment="Left">

        <TextBlock Text="Greeting Module" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Text="This module was discovered by MEF at runtime from the Plugins folder."
                   TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,20"/>

        <ContentControl Content="{Binding NameParam}" Margin="0,0,0,10"/>

        <Button Content="Say Hello"
                Command="{Binding SayHelloCommand}"
                Width="120" HorizontalAlignment="Left"
                Margin="0,10,0,0" Padding="8,6"
                Background="#0078D4" Foreground="White"
                BorderThickness="0" FontSize="13"/>

        <TextBlock Text="{Binding Greeting}" FontSize="20" FontWeight="Bold"
                   Foreground="#0078D4" Margin="0,20,0,0"/>
    </StackPanel>
</UserControl>
